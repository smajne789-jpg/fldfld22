BOT_TOKEN=123456:telegram_bot_token
CRYPTO_PAY_TOKEN=crypto_pay_app_token
ADMIN_IDS=123456789,987654321

# Mainnet: false, testnet: true
CRYPTO_PAY_TESTNET=false

# Optional. If empty, bot username is loaded from Telegram on startup.
BOT_USERNAME=

# Internal database path.
DB_PATH=data/bot.sqlite3

# Displayed/available payout reserve in USD.
DEFAULT_RESERVE_USD=100.00

# Deposits are created as fiat USD invoices. Users can pay with these assets.
ACCEPTED_ASSETS=USDT,TON,BTC,ETH,LTC,BNB,TRX,USDC

# Withdrawals are sent through CryptoBot transfers. USDT keeps 1 USD ~= 1 USDT.
PAYOUT_ASSET=USDT

# Delays make Telegram dice animation visible before the result text.
DICE_ANIMATION_DELAY=2.4
INVOICE_POLL_SECONDS=20
